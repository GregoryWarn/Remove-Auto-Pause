{
	"source": "pause-control.mjs",
	"engines": {
		"bun": ">=1.1.21"
	},
	"type": "module",
	"devDependencies": {
		"@league-of-foundry-developers/foundry-vtt-types": "^9.280.0",
		"@stylistic/eslint-plugin-js": "^2.6.4",
		"eslint": "^9.9.1",
		"eslint-plugin-jsdoc": "^50.2.2",
		"husky": "^9.1.5",
		"lint-staged": "^15.2.9",
		"prettier": "^3.3.3"
	},
	"lint-staged": {
		"*.mjs": "eslint --cache --fix",
		"*.json": "prettier --write"
	},
	"scripts": {
		"release": "bun ./scripts/release.mjs",
		"build": "bun run js && bun run sync",
		"js": "bun build src/pause-control.mjs --sourcemap=linked --minify-whitespace --minify-syntax --outdir dist --entry-naming [name].mjs --root src",
		"js:watch": "bun build src/pause-control.mjs --sourcemap=linked --minify-whitespace --minify-syntax --outdir dist --entry-naming [name].mjs --watch",
		"sync": "bun ./scripts/sync-files.mjs",
		"sync:watch": "bun ./scripts/sync-files.mjs --watch",
		"lint:js": "bunx eslint src",
		"lint:js:fix": "bunx eslint src --cache --fix",
		"ci": "bun install --frozen-lockfile",
		"rebuild": "bun run build"
	},
	"browserslist": "> 5%, last 2 versions, not dead",
	"private": true
}
